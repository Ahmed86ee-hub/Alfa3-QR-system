# قاعدة البيانات
DB_HOST=localhost
DB_NAME=a3itssco_alfa3
DB_USER=a3itssco_alfa3
DB_PASS=your_secure_password_here
DB_CHARSET=utf8mb4

# الجلسات
SESSION_TIMEOUT=1800
SESSION_SECURE=true
SESSION_HTTPONLY=true

# الملفات
UPLOAD_DIR=uploads/
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf

# الأمان
ENABLE_CSRF=true
ENABLE_RATE_LIMIT=true
LOG_ERRORS=true
DEBUG_MODE=false

# البريد الإلكتروني
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=

